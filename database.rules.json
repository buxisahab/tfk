{
  "rules": {
    "articles": {
      ".read": true,
      "$articleId": {
        // Allow write if user is logged in AND (the article is new OR the user is the original author OR the user is the Admin)
        ".write": "auth != null && (!data.exists() || data.child('userId').val() === auth.uid || auth.uid === 'WH3eGCvHoThyz8Jd0MShW5rpI6t1')",
        
        // Ensure that new or updated data always has the correct fields
        ".validate": "newData.hasChildren(['title', 'author', 'content', 'timestamp', 'userId']) && newData.child('userId').val() === auth.uid"
      }
    }
  }
}
